# SuperVolcano Web Portal — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# ─── Firebase Client SDK (browser) ──────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (server) ────────────────────────────────────────
# On Cloud Run / GCE, prefer Application Default Credentials (ADC) and
# leave PRIVATE_KEY/CLIENT_EMAIL unset — only PROJECT_ID is required.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_DATABASE_ID=
FIRESTORE_DATABASE_ID=(default)
FIREBASE_STORAGE_BUCKET=

# ─── PostgreSQL (Robot Intelligence API) ────────────────────────────────
# Runtime app reads DATABASE_URL || POSTGRES_URL || svdb_POSTGRES_URL
# (see src/lib/db/postgres.ts). On Cloud Run this is a Cloud SQL Unix socket
# (host=/cloudsql/<conn-name>).
# POSTGRES_URL_NON_POOLING: Neon-era name, still REQUIRED by the db:schema
# script (scripts/run-schema.ts) — keep it set for local schema runs.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
DATABASE_URL=
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DATABASE=

# ─── Cron + admin auth ──────────────────────────────────────────────────
# CRON_SECRET: legacy bearer token for /api/cron/* — used for local dev only.
# On Cloud Run, cron routes verify Cloud Scheduler OIDC tokens instead.
CRON_SECRET=
ADMIN_BEARER_TOKEN=
MIGRATION_SECRET_KEY=
ROBOT_API_KEY=

# ─── Google Cloud (Drive sync, Maps) ────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Video processing ───────────────────────────────────────────────────
VIDEO_BLUR_PROCESSOR_URL=
VIDEO_BLUR_PROCESSOR_KEY=

# ─── Dev toggles ────────────────────────────────────────────────────────
NEXT_PUBLIC_FIRESTORE_DEBUG=false
