# Production env (Cloud Run service env vars + secrets references)
# Same shape as .env.staging.example but pointed at prod resources.

# --- Public ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sv-firebase-prod
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=prod-db
NEXT_PUBLIC_AUTH_TENANT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Server ---
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE_ID=prod-db
FIREBASE_STORAGE_BUCKET=sv-firebase-prod
DATABASE_URL=postgresql://app_prod@/supervolcano?host=/cloudsql/PROJECT:us-west1:sv-sql-prod

# --- Secrets ---
POSTGRES_PASSWORD=
ADMIN_BEARER_TOKEN=
ROBOT_API_KEY=
MIGRATION_SECRET_KEY=
CRON_SECRET=
VIDEO_BLUR_PROCESSOR_URL=
VIDEO_BLUR_PROCESSOR_KEY=
