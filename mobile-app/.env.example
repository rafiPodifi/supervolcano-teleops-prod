# SuperVolcano Mobile — Environment Variables
# Copy to .env.local for local Expo dev. Never commit .env.local.
# Production builds inject these via EAS env (eas.json profiles).

# ─── Firebase ───────────────────────────────────────────────────────────
# These now point at the GCP project gen-lang-client-0659584673. Legacy
# super-volcano-oem-portal values are retired.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=gen-lang-client-0659584673
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=gen-lang-client-0659584673-sv-firebase-staging
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Named Firestore DB: staging-db or prod-db.
EXPO_PUBLIC_FIREBASE_DATABASE_ID=staging-db
# Identity Platform tenant for this env (staging-ita88 / prod-ftn50).
EXPO_PUBLIC_AUTH_TENANT_ID=staging-ita88

# ─── Web portal API ─────────────────────────────────────────────────────
# Cloud Run service URL: `terraform -chdir=infra/terraform output cloud_run_urls`
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_APP_URL=

# ─── Google Places ──────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
