# SuperVolcano Mobile — Environment Variables
# Copy to .env.local for local Expo dev. Never commit .env.local.
# Production builds inject these via EAS env (eas.json profiles).

# ─── Firebase ───────────────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_ID=

# ─── Web portal API ─────────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=https://supervolcano-teleops.vercel.app
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_APP_URL=

# ─── Google Places ──────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
