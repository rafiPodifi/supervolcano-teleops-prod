# Staging env (Cloud Run service env vars + secrets references)
# Most values come from Secret Manager via gcloud run deploy --update-secrets.
# This file documents the variable names; actual values live in GCP.

# --- Public (browser-exposed) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sv-firebase-staging
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=staging-db
NEXT_PUBLIC_AUTH_TENANT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Server (Cloud Run injected) ---
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE_ID=staging-db
FIREBASE_STORAGE_BUCKET=sv-firebase-staging

# Cloud SQL Auth Proxy unix socket. Cloud Run mounts it when
# --add-cloudsql-instances is set.
DATABASE_URL=postgresql://app_staging@/supervolcano?host=/cloudsql/PROJECT:us-west1:sv-sql-staging

# --- Secrets (mapped via --update-secrets) ---
POSTGRES_PASSWORD=
ADMIN_BEARER_TOKEN=
ROBOT_API_KEY=
MIGRATION_SECRET_KEY=
CRON_SECRET=
VIDEO_BLUR_PROCESSOR_URL=
VIDEO_BLUR_PROCESSOR_KEY=
